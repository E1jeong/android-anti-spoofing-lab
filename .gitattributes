# Normalize line endings regardless of which tool/agent/OS writes a file.
# eol=lf takes precedence over core.autocrlf for matched paths.
* text=auto eol=lf

*.java text eol=lf
*.gradle text eol=lf
*.xml text eol=lf
*.properties text eol=lf
*.md text eol=lf
*.json text eol=lf
gradlew text eol=lf
gradlew.bat text eol=crlf

*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.jar binary
*.keystore binary
*.jks binary
